<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!--
    Permission audit — each comment explains why the permission exists and
    which collector consumes it. If a collector is removed, remove its
    permission. Unused permissions are a code smell in this project.
    -->

    <!-- Foreground service for continuous sensor/behavioral collection -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <!-- Network: ONLY for public-IP lookup collector. No other code path
         may open a socket. See CLAUDE.md rule #1. -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.ACCESS_WIFI_STATE" />

    <!-- Location: LocationCollector. FINE implies COARSE; background not
         needed because collection runs inside a foreground service. -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />

    <!-- Activity recognition: ActivityRecognitionCollector -->
    <uses-permission android:name="android.permission.ACTIVITY_RECOGNITION" />

    <!-- Body sensors: HeartRateCollector (if hardware present) -->
    <uses-permission android:name="android.permission.BODY_SENSORS" />

    <!-- Wifi scanning A13+: WifiScanCollector -->
    <uses-permission android:name="android.permission.NEARBY_WIFI_DEVICES"
        android:usesPermissionFlags="neverForLocation" />

    <!-- Bluetooth: BluetoothCollector -->
    <uses-permission android:name="android.permission.BLUETOOTH_SCAN"
        android:usesPermissionFlags="neverForLocation" />
    <uses-permission android:name="android.permission.BLUETOOTH_CONNECT" />

    <!-- Personal data: opt-in, gated collectors -->
    <uses-permission android:name="android.permission.READ_CONTACTS" />
    <uses-permission android:name="android.permission.READ_CALENDAR" />
    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES" />
    <!-- READ_MEDIA_VIDEO removed: MediaExifCollector only reads images.
         READ_PHONE_STATE removed: no collector uses it. -->

    <!-- Camera/mic: currently not wired to any collector. Uncomment when
         adding the opt-in snapshot collector.
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    -->

    <!-- Special access: requires user to toggle in Settings manually -->
    <uses-permission android:name="android.permission.PACKAGE_USAGE_STATS"
        tools:ignore="ProtectedPermissions" />

    <!-- Restricted (Play Store policy flag): InstalledAppsCollector -->
    <uses-permission android:name="android.permission.QUERY_ALL_PACKAGES"
        tools:ignore="QueryAllPackagesPermission" />

    <!-- Biometric unlock for DB key (USE_FINGERPRINT removed: deprecated) -->
    <uses-permission android:name="android.permission.USE_BIOMETRIC" />

    <!-- ADB-grantable development permissions. Not available via normal UI.
         Grant with: adb shell pm grant <pkg> <permission>
         These survive reboot and do not require root. -->

    <!-- LogcatCollector: full system logcat from all processes -->
    <uses-permission android:name="android.permission.READ_LOGS"
        tools:ignore="ProtectedPermissions" />

    <!-- AppOpsAuditCollector: query which apps used camera/mic/location/contacts -->
    <uses-permission android:name="android.permission.GET_APP_OPS_STATS"
        tools:ignore="ProtectedPermissions" />

    <!-- SystemStatsCollector: dumpsys battery/memory/cpu/process info -->
    <uses-permission android:name="android.permission.DUMP"
        tools:ignore="ProtectedPermissions" />

    <!-- NetworkUsageCollector: per-app network bytes via NetworkStatsManager -->
    <!-- (Uses PACKAGE_USAGE_STATS already declared above + NetworkStatsManager API) -->

    <application
        android:name=".MirrorTrackApp"
        android:allowBackup="false"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="false"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:networkSecurityConfig="@xml/network_security_config"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.MirrorTrack"
        tools:targetApi="31">

        <activity
            android:name=".ui.MainActivity"
            android:exported="true"
            android:theme="@style/Theme.MirrorTrack">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Continuous collection foreground service -->
        <service
            android:name=".scheduling.CollectionForegroundService"
            android:exported="false"
            android:foregroundServiceType="specialUse">
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="Local personal-data mirror collection; no network transmission." />
        </service>

        <!-- Screen on/off broadcast receiver (programmatically registered too;
             this entry is for future boot-completed re-registration.) -->
        <receiver
            android:name=".collectors.behavioral.BootReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
            </intent-filter>
        </receiver>

        <!-- Notification listener for MirrorNotificationListenerService -->
        <service
            android:name=".collectors.apps.MirrorNotificationListenerService"
            android:permission="android.permission.BIND_NOTIFICATION_LISTENER_SERVICE"
            android:exported="true">
            <intent-filter>
                <action android:name="android.service.notification.NotificationListenerService" />
            </intent-filter>
        </service>

    </application>
</manifest>
